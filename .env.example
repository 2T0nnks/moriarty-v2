# URL of the backend API (used by the Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# (Optional) Additional allowed CORS origins for the backend, comma-separated.
# localhost and *.manus.computer are always allowed by default.
# Example: CORS_ORIGINS=https://myapp.example.com,https://other.example.com
# CORS_ORIGINS=
